SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Server Configuration
# Port to run the development server on (use 6000-6001 to avoid conflicts)
SERVER_PORT=6000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# Set USE_SQLITE=True to use SQLite instead of PostgreSQL (for quick testing)
USE_SQLITE=False

# PostgreSQL settings (ignored if USE_SQLITE=True)
DATABASE_NAME=inspection_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Company/Facility Name
COMPANY_NAME=Your Company Name
