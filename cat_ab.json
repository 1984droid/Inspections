{
  "template": {
    "code": "a92.2-2021-test-dielectric-cat-a-b",
    "name": "ANSI A92.2 (2021) Dielectric Test - Category A/B",
    "version": "v2",
    "kind": "test"
  },
  "rules": {
    "fail_requires_defect_note": true,
    "fail_requires_photo": true,
    "photo_scope": "per_defect"
  },
  "sections": [
    {
      "code": "ab_test_documentation",
      "title": "Test Documentation (ANSI 5.6.3)",
      "ansi_reference": "5.6.3",
      "display_group": "Test Documentation",
      "questions": [
        { "prompt": "Name of entity performing test documented.", "required": true },
        { "prompt": "Make, model, and serial number of aerial device documented.", "required": true },
        { "prompt": "Electrical Category (A or B) documented.", "required": true },
        { "prompt": "Rated Line Voltage documented.", "required": true },
        { "prompt": "Test type designated: Qualification or Periodic Test.", "required": true },
        { "prompt": "Test voltage type (AC or DC) documented.", "required": true },
        { "prompt": "Date of test documented.", "required": true },
        { "prompt": "Signature/name of person performing test documented.", "required": true }
      ]
    },
    {
      "code": "ab_bonding_and_platform",
      "title": "Setup - Bonding & Platform",
      "ansi_reference": "5.4.3.1",
      "display_group": "Setup",
      "questions": [
        { "prompt": "All conductive material at upper end of insulating boom electrically bonded during test (per Figure 5).", "required": true },
        { "prompt": "If non-conductive platform (Category A): metal liner installed and bonded prior to test.", "required": true }
      ]
    },
    {
      "code": "ab_pretest_system_checks",
      "title": "Setup - Pre-test System Checks",
      "ansi_reference": "5.4.3.1",
      "display_group": "Setup",
      "questions": [
        { "prompt": "Vacuum limiting system visually inspected and function verified per manufacturer manual.", "required": true },
        { "prompt": "Lower test electrode system inspected for completeness and tested for continuity (intact).", "required": true },
        { "prompt": "All hydraulic lines crossing insulating boom section/system filled with oil by operating unit prior to test.", "required": true },
        { "prompt": "If continuity across joints cannot be ensured: shunting required and installed (per Figure 1).", "required": true },
        { "prompt": "If chassis insulating system equipped: shunted as shown in Figure 3A.", "required": true }
      ]
    },
    {
      "code": "ab_grounding_and_metering",
      "title": "Setup - Grounding & Metering",
      "ansi_reference": "5.4.3.1",
      "display_group": "Setup",
      "questions": [
        { "prompt": "Vehicle chassis grounded.", "required": true },
        { "prompt": "Current meter receptacle connected through shielded cable to current meter (when used) and then to ground.", "required": true },
        { "prompt": "Booms positioned as shown in Figure 1 or Figure 4.", "required": true }
      ]
    },
    {
      "code": "ab_test_method_and_results",
      "title": "Test Execution and Results",
      "ansi_reference": "5.4.3.1",
      "display_group": "Test Execution and Results",
      "questions": [
        { "prompt": "One of the following tests performed: (a) AC test per Table 2, (b) DC test per Table 2, (c) Quarterly before-use high voltage line test per Table 3, (d) Energized AC line contact test per Table 3.", "required": true },
        { "prompt": "Applied test voltage (kV)", "required": true, "type": "measurement", "unit": "kV" },
        { "prompt": "Final leakage current value", "required": true, "type": "measurement", "unit": "mA or µA" },
        { "prompt": "Test voltage and final current value documented per ANSI 5.6.3.", "required": true },
        { "prompt": "Did equipment pass dielectric test per applicable Table 2 or Table 3 criteria?", "required": true }
      ]
    }
  ],
  "fields": [
    { "code": "entity_name", "label": "Name of Entity Performing Test", "type": "text", "required": true },
    { "code": "electrical_category", "label": "Electrical Category", "type": "choice", "required": true, "options": ["Category A", "Category B"] },
    { "code": "rated_line_voltage", "label": "Rated Line Voltage", "type": "number", "required": true, "unit_hint": "kV" },
    { "code": "test_designation", "label": "Test Designation", "type": "choice", "required": true, "options": ["Qualification Test", "Periodic Test"] },
    {
      "code": "test_method",
      "label": "Test Method Used",
      "type": "choice",
      "required": true,
      "options": [
        "AC test (Table 2)",
        "DC test (Table 2)",
        "Quarterly before-use line test (Table 3)",
        "Energized AC line contact test (Table 3)"
      ]
    },
    { "code": "test_type", "label": "Test Voltage Type", "type": "choice", "required": true, "options": ["AC", "DC"] },
    { "code": "test_voltage", "label": "Applied Test Voltage", "type": "number", "required": true, "unit_hint": "kV" },
    { "code": "final_current", "label": "Final Leakage Current Value", "type": "number", "required": true, "unit_hint": "mA or µA" },
    { "code": "test_date", "label": "Date of Test", "type": "date", "required": true },
    { "code": "performed_by", "label": "Person Performing Test (Name/Signature)", "type": "text", "required": true },
    {
      "code": "test_result",
      "label": "Overall Dielectric Test Result",
      "type": "passfail",
      "required": true
    },
    { "code": "notes", "label": "General Notes", "type": "text", "required": false }
  ]
}
