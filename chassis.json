{
  "template": {
    "code": "a92.2-2021-test-chassis-insulating-system",
    "name": "ANSI A92.2 (2021) Test - Chassis Insulating System",
    "version": "v2",
    "kind": "test"
  },
  "rules": {
    "fail_requires_defect_note": true,
    "fail_requires_photo": true,
    "photo_scope": "per_defect"
  },
  "sections": [
    {
      "code": "chassis_test_documentation",
      "title": "Test Documentation (ANSI 5.6.3)",
      "ansi_reference": "5.6.3",
      "display_group": "Test Documentation",
      "questions": [
        { "prompt": "Name of entity performing test documented.", "required": true },
        { "prompt": "Make, model, and serial number of aerial device documented.", "required": true },
        { "prompt": "Electrical Category documented.", "required": true },
        { "prompt": "Rated Line Voltage documented.", "required": true },
        { "prompt": "Test type designated: Qualification or Periodic Test.", "required": true },
        { "prompt": "Test voltage type (AC or DC) documented.", "required": true },
        { "prompt": "Date of test documented.", "required": true },
        { "prompt": "Signature/name of person performing test documented.", "required": true }
      ]
    },
    {
      "code": "chassis_setup",
      "title": "Setup",
      "ansi_reference": "5.4.3.4",
      "display_group": "Setup",
      "questions": [
        { "prompt": "Voltage applied to the metal above the insulating system.", "required": true },
        { "prompt": "All hydraulic lines crossing the insulating system filled with oil during the test.", "required": true },
        { "prompt": "Mobile unit (MEWP) connected through shielded cable to current meter and then connected to ground.", "required": true },
        { "prompt": "Booms positioned for test as shown in Figure 3.", "required": true }
      ]
    },
    {
      "code": "chassis_execution",
      "title": "Test Execution and Results",
      "ansi_reference": "5.4.3.4",
      "display_group": "Test Execution and Results",
      "questions": [
        { "prompt": "One of the following tests performed: (a) AC voltage of 35 kV for 3 minutes (current not to exceed 3 milliamperes), (b) DC test voltage of 50 kV for 3 minutes (current not to exceed 100 microamperes).", "required": true },
        { "prompt": "Applied test voltage (kV)", "required": true, "type": "measurement", "unit": "kV" },
        { "prompt": "Test duration (minutes)", "required": true, "type": "measurement", "unit": "minutes" },
        { "prompt": "Final current value", "required": true, "type": "measurement", "unit": "mA or µA" },
        { "prompt": "Test voltage and final current value documented per ANSI 5.6.3.", "required": true },
        { "prompt": "Did chassis insulating system pass test per ANSI 5.4.3.4 criteria?", "required": true }
      ]
    }
  ],
  "fields": [
    { "code": "entity_name", "label": "Name of Entity Performing Test", "type": "text", "required": true },
    { "code": "electrical_category", "label": "Electrical Category", "type": "choice", "required": true, "options": ["Category A", "Category B", "Category C", "Category D", "Category E"] },
    { "code": "rated_line_voltage", "label": "Rated Line Voltage", "type": "number", "required": true, "unit_hint": "kV" },
    { "code": "test_designation", "label": "Test Designation", "type": "choice", "required": true, "options": ["Qualification Test", "Periodic Test"] },
    {
      "code": "test_method",
      "label": "Test Method Used",
      "type": "choice",
      "required": true,
      "options": [
        "AC 35 kV for 3 minutes (max 3 mA)",
        "DC 50 kV for 3 minutes (max 100 µA)"
      ]
    },
    { "code": "test_type", "label": "Test Voltage Type", "type": "choice", "required": true, "options": ["AC", "DC"] },
    { "code": "test_voltage", "label": "Applied Test Voltage", "type": "number", "required": true, "unit_hint": "kV" },
    { "code": "duration", "label": "Test Duration", "type": "number", "required": true, "unit_hint": "minutes (3 min for both AC and DC)" },
    { "code": "final_current", "label": "Final Current Value", "type": "number", "required": true, "unit_hint": "mA for AC, µA for DC" },
    { "code": "test_date", "label": "Date of Test", "type": "date", "required": true },
    { "code": "performed_by", "label": "Person Performing Test (Name/Signature)", "type": "text", "required": true },
    { "code": "test_result", "label": "Overall Chassis Insulating System Test Result", "type": "passfail", "required": true },
    { "code": "notes", "label": "General Notes", "type": "text", "required": false }
  ]
}
